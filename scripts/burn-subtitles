# TODO: (fancy):  ~  ffmpeg -i Three\ Identical\ Strangers\ 2018\ 1080p\ Bluray\ DD5\ 1\ x264-MidgetClan.mkv -vf "scale=3840:2160:force_original_aspect_ratio=decrease:flags=lanczos+accurate_rnd+full_chroma_int,pad=3840:2160:(ow-iw)/2:(oh-ih)/2,subtitles=Three Identical Strangers 2018 1080p Bluray DD5 1 x264-MidgetClan.pl.srt:force_style='FontName=Ubuntu-R,Outline=0.6',scale=1920:1080:flags=lanczos+accurate_rnd+full_chroma_int" -c:v libx264 -crf 20 -profile:v high -level 4.1 -preset faster -tune film -x264-params "no-dct-decimate=1:aq-mode=2:aq-strength=0.9:psy-rd=1.0:psy-trellis=0.12:mbtree=0" -c:a aac -ac 2 -b:a 192k -ar 48000 -sn -map_metadata -1 -movflags +faststart three-identical-strangers-fancy.mp4


# TODO (with constant frame rate): ~  ffmpeg -i Three\ Identical\ Strangers\ 2018\ 1080p\ Bluray\ DD5\ 1\ x264-MidgetClan.mkv -vf "scale=3840:2160:force_original_aspect_ratio=decrease:flags=lanczos+accurate_rnd+full_chroma_int,pad=3840:2160:(ow-iw)/2:(oh-ih)/2,subtitles=Three Identical Strangers 2018 1080p Bluray DD5 1 x264-MidgetClan.pl.srt:force_style='FontName=Ubuntu-R,Outline=0.6',scale=1920:1080:flags=lanczos+accurate_rnd+full_chroma_int,fps=fps=source_fps" -c:v libx264 -crf 20 -profile:v high -level 4.1 -preset faster -tune film -c:a aac -ac 2 -b:a 192k -ar 48000 -sn -map_metadata -1 -movflags +faststart three-identical-strangers.mp4

# TODO: if required split the file into parts so that it fits on fat32
